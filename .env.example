# ============================================
# JSR_Auto - Environment Configuration
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=production
BASE_URL=https://jsr-auto.onrender.com
FRONTEND_URL=https://jsr-auto.onrender.com

# Security
JWT_SECRET=your_jwt_secret_here_min_32_chars
SESSION_SECRET=your_session_secret_here_min_32_chars
ALLOWED_ORIGINS=https://jsr-auto.onrender.com,http://localhost:3000

# GitHub Configuration
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_REPO_OWNER=Shivpvtltd
GITHUB_REPO_NAME=JSR_Automation
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# YouTube OAuth 2.0
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REDIRECT_URI=https://jsr-auto.onrender.com/auth/youtube/callback

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your_project.firebaseio.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=yt-autopilot

# Notification Webhooks (Optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Schedule Configuration (IST - Asia/Kolkata)
# Main workflow trigger: 12:05 AM IST
MAIN_CRON="5 0 * * *"
# Backup check: 4:00 AM IST  
BACKUP_CRON="0 4 * * *"
# Long video publish: 5:00 PM IST
LONG_PUBLISH_HOUR=17
LONG_PUBLISH_MINUTE=0
# Shorts publish: 5:30 PM IST
SHORTS_PUBLISH_HOUR=17
SHORTS_PUBLISH_MINUTE=30

# Timezone
TZ=Asia/Kolkata
